<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarAdsApp.MVVM.Views.UlubioneStrona"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Ulubione">

    <VerticalStackLayout Padding="20" Spacing="10">

        <CollectionView ItemsSource="{Binding Ulubione}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10">
                        <VerticalStackLayout Padding="10">
                            <Label Text="{Binding Tytul}" FontAttributes="Bold"/>
                            <Label Text="{Binding Cena}" TextColor="Green"/>
                            <Label Text="{Binding Lokalizacja}" FontSize="12"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>

</ContentPage>
