<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarAdsApp.MVVM.Views.WszystkieOgloszeniaStrona"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Wszystkie ogłoszenia">

    <CollectionView ItemsSource="{Binding Ogloszenia}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="10" Padding="0" >

                    <Grid RowDefinitions="150,Auto">

                        <Image 
                        Source="{Binding ZdjecieUrl}"
                        Aspect="AspectFill" />

                        <VerticalStackLayout Grid.Row="1" Padding="10">

                            <Label 
                            Text="{Binding Tytul}"
                            FontSize="16"
                            FontAttributes="Bold"/>

                            <Label 
                            Text="{Binding Cena}"
                            TextColor="Green"/>

                            <Label 
                            Text="{Binding Lokalizacja}"
                            FontSize="12"/>

                            <Button 
                                Text="❤️ Polub"
                                FontSize="12"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PolubKomenda}"
                                CommandParameter="{Binding .}" />

                        </VerticalStackLayout>

                    </Grid>

                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
