<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarAdsApp.MVVM.Views.WszystkieOgloszeniaStrona"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Wszystkie ogłoszenia">

    <CollectionView>
        <CollectionView.ItemsSource>
            <x:Array Type="{x:Type x:String}">
                <x:String>BMW E46 - 8000 zł</x:String>
                <x:String>Audi A4 - 12000 zł</x:String>
                <x:String>Golf V - 7000 zł</x:String>
            </x:Array>
        </CollectionView.ItemsSource>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10" Padding="10">
                    <Label Text="{Binding}" FontSize="18"/>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>