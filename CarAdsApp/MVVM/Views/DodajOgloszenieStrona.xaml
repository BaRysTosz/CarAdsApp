<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarAdsApp.MVVM.Views.DodajOgloszenieStrona"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dodaj ogłoszenie">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Entry Placeholder="Tytuł" />
            <Entry Placeholder="Cena" Keyboard="Numeric"/>
            <Entry Placeholder="Marka" />
            <Entry Placeholder="Model" />
            <Entry Placeholder="Rok" Keyboard="Numeric"/>
            <Entry Placeholder="Przebieg" Keyboard="Numeric"/>
            <Entry Placeholder="Paliwo" />
            <Entry Placeholder="Lokalizacja" />
            <Entry Placeholder="Telefon" Keyboard="Telephone"/>

            <Editor Placeholder="Opis" HeightRequest="100"/>

            <Button Text="Dodaj ogłoszenie"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>