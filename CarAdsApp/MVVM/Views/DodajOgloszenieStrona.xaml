<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarAdsApp.MVVM.Views.DodajOgloszenieStrona"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dodaj ogłoszenie">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Dodaj nowe ogłoszenie" FontSize="20" FontAttributes="Bold"/>

            <Entry Placeholder="Tytuł" />
            <Entry Placeholder="Cena (zł)" Keyboard="Numeric"/>

            <Label Text="Dane pojazdu" FontAttributes="Bold"/>

            <Entry Placeholder="Marka" />
            <Entry Placeholder="Model" />
            <Entry Placeholder="Rok" Keyboard="Numeric"/>
            <Entry Placeholder="Przebieg (km)" Keyboard="Numeric"/>
            <Entry Placeholder="Paliwo" />

            <Label Text="Kontakt" FontAttributes="Bold"/>

            <Entry Placeholder="Lokalizacja" />
            <Entry Placeholder="Telefon" Keyboard="Telephone"/>

            <Editor Placeholder="Opis ogłoszenia" HeightRequest="120"/>

            <Button 
                Text="Dodaj ogłoszenie"
                BackgroundColor="Green"
                TextColor="White"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>