<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CarAdsApp.MVVM.Views.MojeOgloszeniaStrona"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Moje ogłoszenia">

    <CollectionView ItemsSource="{Binding MojeOgloszenia}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Margin="10" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="{Binding Tytul}" FontAttributes="Bold"/>
                        <Label Text="{Binding Cena}" TextColor="Green"/>
                        <Label Text="{Binding Lokalizacja}" FontSize="12"/>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>