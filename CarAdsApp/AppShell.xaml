<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CarAdsApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CarAdsApp.MVVM.Views">

    <TabBar>

        <ShellContent 
            Title="Wszystkie"
            ContentTemplate="{DataTemplate views:WszystkieOgloszeniaStrona}" />

        <ShellContent 
            Title="Ulubione"
            ContentTemplate="{DataTemplate views:UlubioneStrona}" />

        <ShellContent 
            Title="Dodaj"
            ContentTemplate="{DataTemplate views:DodajOgloszenieStrona}" />

        <ShellContent 
            Title="Moje"
            ContentTemplate="{DataTemplate views:MojeOgloszeniaStrona}" />

    </TabBar>

</Shell>
